<Window x:Class="GlassTodo.LockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔒 专注时间结束" 
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        Background="#1A1A1A"
        ResizeMode="NoResize"
        Focusable="True"
        KeyDown="Window_KeyDown"
        FocusManager.FocusedElement="{Binding ElementName=txtAnswer}"> <!-- ✅ 新增：自动聚焦到输入框 -->
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel HorizontalAlignment="Center" Width="450">
            
            <TextBlock Text="请放松休息" 
                       FontSize="24" 
                       Foreground="#AAAAAA" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,10"/>
                       
            <TextBlock x:Name="txtRestCountdown" 
                       Text="00:00" 
                       FontSize="80" 
                       FontWeight="Bold" 
                       Foreground="#4CAF50" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,50" 
                       TextAlignment="Center"/>
            
            <Border Background="#2D2D2D" CornerRadius="12" Padding="30" Margin="0,0,0,30" BorderBrush="#333" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="🧮 回答正确即可解锁" FontSize="18" Foreground="#AAA" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock x:Name="txtQuestion" 
                               Text="15 + 7 = ?" 
                               FontSize="36" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,20"/>
                    <TextBox x:Name="txtAnswer" 
                             FontSize="24" 
                             Padding="15" 
                             Background="#1A1A1A" 
                             Foreground="White" 
                             BorderBrush="#4CAF50" 
                             BorderThickness="2" 
                             HorizontalContentAlignment="Center"/>
                    <TextBlock x:Name="txtError" 
                               Text="" 
                               Foreground="#F44336" 
                               HorizontalAlignment="Center" 
                               Margin="0,10,0,0" 
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>
            
            <Button Content="✅ 确认解锁" 
                    FontSize="20" 
                    Padding="40,15" 
                    Background="#2196F3" 
                    Foreground="White" 
                    BorderThickness="0" 
                    Cursor="Hand" 
                    Click="UnlockButton_Click" 
                    HorizontalAlignment="Center"/>
            <TextBlock Text="💡 提示：管理员可按 Ctrl+Shift+M 强制解锁" 
                       FontSize="12" 
                       Foreground="#666" 
                       HorizontalAlignment="Center" 
                       Margin="0,20,0,0"/>
        </StackPanel>
    </Grid>
</Window>