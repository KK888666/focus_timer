<Window x:Class="GlassTodo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⏱ 专注锁屏控制器" Height="520" Width="480"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        Background="#1A1A1A">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="AppTitle" Text="⏱ 专注锁屏控制器" FontSize="26" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- 1. 首次设置面板 -->
        <Grid x:Name="SetupPanel" Grid.Row="1" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">
                <TextBlock Text="📋 首次使用，请完成初始化设置" FontSize="18" Foreground="#FFF" HorizontalAlignment="Center" Margin="0,0,0,25"/>
                
                <TextBlock Text="专注时长（分钟）" FontSize="15" Foreground="#AAA" Margin="0,0,0,6"/>
                <TextBox x:Name="txtSetupFocus" FontSize="18" Padding="10" Text="25" Background="#2A2A2A" Foreground="White" BorderBrush="#4CAF50" BorderThickness="1" HorizontalContentAlignment="Center"/>
                
                <TextBlock Text="休息时长（分钟）" FontSize="15" Foreground="#AAA" Margin="0,15,0,6"/>
                <TextBox x:Name="txtSetupRest" FontSize="18" Padding="10" Text="5" Background="#2A2A2A" Foreground="White" BorderBrush="#2196F3" BorderThickness="1" HorizontalContentAlignment="Center"/>
                
                <Button Content="✅ 保存并进入主界面" FontSize="18" FontWeight="Bold" Padding="0,12" Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnFinishSetup_Click" Margin="0,30,0,0"/>
            </StackPanel>
        </Grid>

        <!-- 2. 默认主界面（简洁版） -->
        <Grid x:Name="MainPanel" Grid.Row="1" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="👋 欢迎回来" FontSize="24" Foreground="#FFF" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBlock x:Name="txtConfigSummary" Text="专注 25 分钟 | 休息 5 分钟" FontSize="18" Foreground="#AAA" HorizontalAlignment="Center" Margin="0,0,0,40"/>
                
                <Button Content="🚀 立即开始专注" FontSize="24" FontWeight="Bold" Padding="40,18" Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnQuickStart_Click" Margin="0,0,0,25"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="⚙ 修改设置" FontSize="16" Padding="25,10" Background="Transparent" Foreground="#2196F3" BorderThickness="1" BorderBrush="#2196F3" Cursor="Hand" Click="BtnOpenSettings_Click"/>
                    <Button Content="ℹ 关于" FontSize="16" Padding="25,10" Background="Transparent" Foreground="#888" BorderThickness="1" BorderBrush="#555" Cursor="Hand" Click="BtnAbout_Click" Margin="15,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- 3. 设置编辑页面 -->
        <Grid x:Name="SettingsPanel" Grid.Row="1" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">
                <TextBlock Text="⚙ 参数设置" FontSize="20" FontWeight="Bold" Foreground="#FFF" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                
                <TextBlock Text="专注时长（分钟）" FontSize="15" Foreground="#AAA" Margin="0,0,0,6"/>
                <TextBox x:Name="txtEditFocus" FontSize="18" Padding="10" Background="#2A2A2A" Foreground="White" BorderBrush="#4CAF50" BorderThickness="1" HorizontalContentAlignment="Center"/>
                
                <TextBlock Text="休息时长（分钟）" FontSize="15" Foreground="#AAA" Margin="0,15,0,6"/>
                <TextBox x:Name="txtEditRest" FontSize="18" Padding="10" Background="#2A2A2A" Foreground="White" BorderBrush="#2196F3" BorderThickness="1" HorizontalContentAlignment="Center"/>
                
                <TextBlock x:Name="txtSaveHint" Text="✅ 已保存" FontSize="14" Foreground="#4CAF50" HorizontalAlignment="Center" Margin="0,10,0,0" Visibility="Collapsed"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
                    <Button Content="💾 保存并返回" FontSize="17" Padding="25,10" Background="#2196F3" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnSaveAndBack_Click"/>
                    <Button Content="🔙 取消" FontSize="17" Padding="25,10" Background="#444" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnCancelSettings_Click" Margin="15,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- 4. 倒计时状态面板（专注/休息） -->
        <Grid x:Name="StatusPanel" Grid.Row="1" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="txtStatusTitle" Text="专注中..." FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBlock x:Name="txtStatusTime" Text="25:00" FontSize="90" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Center" Margin="0,0,0,25"/>
                <TextBlock Text="已最小化至右下角托盘，双击图标恢复" FontSize="14" Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                <Button Content="🛑 强制结束" FontSize="16" Padding="25,10" Background="#F44336" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnForceStop_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>